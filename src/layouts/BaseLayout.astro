---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileActionBar from "../components/MobileActionBar.astro";
import { site } from "../../lib/site";
import {
  localBusinessSchema,
  organizationSchema,
  personSchema,
  websiteSchema,
} from "../../lib/schema";

export interface Props {
  title: string;
  description: string;
  path: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  imageAlt?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  heroPreload?: {
    href: string;
    srcset?: string;
    sizes?: string;
  };
}

const {
  title,
  description,
  path,
  ogTitle,
  ogDescription,
  ogImage,
  imageAlt,
  schema = [],
  heroPreload,
} = Astro.props;

const canonicalPath = path === "/" ? "/" : `${path.replace(/\/$/, "")}/`;
const canonicalUrl = new URL(canonicalPath, site.url).toString();
const pageTitle = title.includes(site.name) ? title : `${title} | ${site.name}`;
const socialTitle = ogTitle ?? title;
const socialDescription = ogDescription ?? description;
const socialImagePath = ogImage?.startsWith("/images/") ? ogImage : site.ogImage;
const socialImage = socialImagePath.startsWith("http") ? socialImagePath : `${site.url}${socialImagePath}`;
const schemaItems = [
  organizationSchema(),
  localBusinessSchema(),
  websiteSchema(),
  personSchema(),
  ...(Array.isArray(schema) ? schema : [schema]),
].filter(Boolean);
const speculationRules = {
  prerender: [
    {
      source: "list",
      urls: [
        "/free-credit-repair-consultation-phoenix/",
        "/credit-repair-cost-phoenix-az/",
        "/credit-repair-services-phoenix-az/",
      ],
    },
  ],
  prefetch: [
    {
      source: "document",
      where: { href_matches: "/*" },
      eagerness: "moderate",
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {heroPreload ? (
      <link
        rel="preload"
        as="image"
        href={heroPreload.href}
        imagesrcset={heroPreload.srcset}
        imagesizes={heroPreload.sizes}
        fetchpriority="high"
      />
    ) : null}
    <style is:inline>
      :root{--bg:#141210;--text:#f6efe8;--accent:#c4622d;--trust:#2bbfb3;--font:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}
      *,*::before,*::after{box-sizing:border-box}
      html{background:var(--bg);color:var(--text);font-family:var(--font);line-height:1.6;text-rendering:optimizeLegibility;-webkit-font-smoothing:antialiased}
      body{margin:0;min-height:100dvh;background:var(--bg);color:var(--text)}
      img,svg{display:block;max-width:100%}
      a{color:inherit}
      .site-header{position:sticky;top:0;z-index:80;background:rgba(20,18,16,.94);border-bottom:1px solid rgba(255,255,255,.08)}
      .announcement{background:#100e0c;border-bottom:1px solid rgba(255,255,255,.08)}
      .mobile-action-bar{display:none}
    </style>
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={imageAlt ?? socialTitle} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="theme-color" content="#141210" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    {schemaItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <MobileActionBar />
    <script is:inline type="speculationrules" set:html={JSON.stringify(speculationRules)}></script>
  </body>
</html>
