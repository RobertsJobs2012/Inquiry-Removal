---
import { ClientRouter } from "astro:transitions";
import { localBusinessSchema, organizationSchema, websiteSchema } from "@/lib/schema";
import MobileDock from "../components/MobileDock.astro";
import InstantPageWarmup from "../components/InstantPageWarmup.astro";
import "../styles/global.css";

const {
  title,
  description,
  canonicalPath,
  ogImage = "/og/home.png",
  ogImageAlt = "Inquiry Removal hard inquiry removal service preview.",
  ogImageWidth = 1200,
  ogImageHeight = 630,
  ogImageType = "image/png",
  schema = [],
  pathname = "/",
} = Astro.props;

function normalizeCanonicalPath(path = "/") {
  const cleanPath = path || "/";
  const [pathnameWithMaybeHash, search = ""] = cleanPath.split("?");
  const [pathnameOnly, hash = ""] = pathnameWithMaybeHash.split("#");
  const lastSegment = pathnameOnly.split("/").filter(Boolean).pop() || "";
  const looksLikeFile = /\.[a-z0-9]{2,8}$/i.test(lastSegment);
  const normalizedPath = pathnameOnly === "/" || looksLikeFile || pathnameOnly.endsWith("/")
    ? pathnameOnly
    : `${pathnameOnly}/`;
  return `${normalizedPath}${hash ? `#${hash}` : ""}${search ? `?${search}` : ""}`;
}

const siteOrigin = "https://www.inquiryremoval.com";
const pageUrl = new URL(normalizeCanonicalPath(canonicalPath), siteOrigin).toString();
const socialImageUrl = new URL(ogImage, siteOrigin).toString();
const extraSchema = Array.isArray(schema) ? schema : [schema];
const schemaPayload = [organizationSchema, localBusinessSchema, websiteSchema, ...extraSchema].filter(Boolean);
---

<!doctype html>
<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <ClientRouter fallback="swap" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:secure_url" content={socialImageUrl} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="Inquiry Removal" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <meta name="theme-color" content="#0A0A0F" />
    <link
      rel="preload"
      as="image"
      href="/inquiry-removal-logo-178.avif"
      imagesrcset="/inquiry-removal-logo-150.avif 150w, /inquiry-removal-logo-178.avif 178w, /inquiry-removal-logo-249.avif 249w, /inquiry-removal-logo-300.avif 300w, /inquiry-removal-logo-356.avif 356w"
      imagesizes="(max-width: 380px) 122px, (max-width: 1079px) 142px, 178px"
      type="image/avif"
    />
    <link rel="icon" href="/favicon.png" sizes="64x64" type="image/png" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    {
      schemaPayload.map((item) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <slot />
    <MobileDock pathname={pathname} />
    <InstantPageWarmup />
  </body>
</html>
