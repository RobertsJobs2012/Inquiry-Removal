---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { getAllBlogPosts } from "../../lib/blog";
import {
  homeBigNumbers,
  homeFaq,
  homeFeatureTiles,
  homeHero,
  homeHowItWorks,
  homePainCards,
  homePageMeta,
  homeServiceArea,
  homeSolution,
  homeTestimonials,
} from "../../lib/homepage";
import { resultsGallery } from "../../lib/resultsGallery";
import { getStartedPagePath } from "../../lib/getStartedPage";
import { pricingPagePath } from "../../lib/pricingPage";
import { servicesPagePath } from "../../lib/servicesPage";
import { faqSchema, howToSchema, serviceSchema } from "../../lib/schema";
import { packages, stats } from "../../lib/site";

const posts = getAllBlogPosts().slice(0, 2);
---

<BaseLayout
  title={homePageMeta.title}
  description={homePageMeta.description}
  path="/"
  ogTitle={homePageMeta.ogTitle}
  ogDescription={homePageMeta.ogDescription}
  schema={[faqSchema(homeFaq), serviceSchema(), howToSchema(homeHowItWorks)]}
  heroPreload={{
    href: "/images/results/maria-c-final-score-710.avif",
    srcset: "/images/results/maria-c-final-score-710.avif 1200w",
    sizes: "(min-width: 980px) 430px, 92vw",
  }}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{homeHero.badge}</p>
        <h1>{homeHero.titleLead}. {homeHero.titleHighlight} {homeHero.titleTail}.</h1>
        <p>{homeHero.description}</p>
        <div class="hero-actions">
          <a class="button button-primary" href={getStartedPagePath} data-astro-prefetch>
            {homeHero.primaryCta} <Icon name="arrow-right" size={17} />
          </a>
          <a class="button button-secondary" href="/how-credit-repair-works/" data-astro-prefetch>
            {homeHero.secondaryCta} <Icon name="arrow-right" size={17} />
          </a>
        </div>
        <p>{homeHero.fearKiller}</p>
      </div>

      <figure class="hero-media">
        <img
          src="/images/results/maria-c-final-score-710.avif"
          alt="State 48 Credit Phoenix client score result after credit repair"
          width="1200"
          height="1501"
          loading="eager"
          fetchpriority="high"
        />
        <figcaption>
          <strong>Mortgage-ready in 67 days</strong>
          <span>11 collections and 1 repossession removed for a Phoenix client.</span>
        </figcaption>
      </figure>
    </div>

    <div class="container stat-strip">
      {homeHero.stats.map((item) => (
        <article class="card stat-card">
          <strong>{item.value}</strong>
          <span>{item.label}</span>
        </article>
      ))}
      <article class="card stat-card">
        <strong>${stats.debtEliminated}</strong>
        <span>derogatory debt eliminated</span>
      </article>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">By the numbers</p>
        <h2>Arizona credit repair with receipts.</h2>
        <p>Every number below connects to real client outcomes: removed items, deleted debt, cleaner reports, and better approval odds.</p>
      </div>
      <div class="grid-4">
        {homeBigNumbers.map((item) => (
          <article class="card stat-card">
            <span class="eyebrow">{item.eyebrow}</span>
            <strong class="big-number">{item.number}</strong>
            <p>{item.caption}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">What is happening</p>
        <h2>Bad credit keeps showing up in real life.</h2>
        <p>Most clients come to State 48 after the same problems have already cost them time, approvals, money, and peace of mind.</p>
      </div>
      <div class="grid-3">
        {homePainCards.map((card) => (
          <article class="card">
            <h3>{card.title}</h3>
            {card.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container split">
      <div class="section-head">
        <p class="eyebrow">Our process</p>
        <h2>{homeSolution.title}</h2>
        {homeSolution.paragraphs.slice(0, 3).map((paragraph) => <p>{paragraph}</p>)}
        <a class="text-link" href={servicesPagePath} data-astro-prefetch>
          {homeSolution.cta} <Icon name="arrow-right" size={15} />
        </a>
      </div>
      <div class="grid-1">
        {homeHowItWorks.map((step) => (
          <article class="card">
            <p class="eyebrow">Step {step.step} - {step.actor}</p>
            <h3>{step.title}</h3>
            <p>{step.detail}</p>
            <p><strong>{step.duration}</strong></p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Packages</p>
        <h2>Flat-fee credit repair packages.</h2>
        <p>No monthly billing trap. Pick the scope that matches the report, then let the free audit confirm it.</p>
      </div>
      <div class="grid-3">
        {packages.map((pkg) => (
          <article class:list={["pricing-card", { featured: pkg.featured }]}>
            {pkg.featured ? <span class="badge">Most popular</span> : null}
            <h3>{pkg.name}</h3>
            <p>{pkg.tagline}</p>
            <p class="price">${pkg.price}<small> one-time</small></p>
            <p>{pkg.bestFor}</p>
            <ul class="check-list">
              {pkg.features.slice(0, 5).map((feature) => (
                <li><Icon name="check" size={16} /> <span>{feature}</span></li>
              ))}
            </ul>
            <a class="button button-primary" href={pricingPagePath} data-astro-prefetch>Compare pricing</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Real outcomes</p>
        <h2>Recent Arizona credit repair results.</h2>
        <p>These proof frames stay static, lightweight, and readable with JavaScript disabled.</p>
      </div>
      <div class="results-grid">
        {resultsGallery.map((item) => (
          <article class="result-card">
            <img src={item.imageSrc} alt={item.imageAlt} width="1200" height="1501" loading="lazy" decoding="async" />
            <div>
              <p class="score">{item.score}</p>
              <h3>{item.name}</h3>
              <p>{item.city} - {item.timeframe}</p>
              <p>{item.outcome}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Why State 48</p>
        <h2>Custom disputes, direct accountability, and a real finish line.</h2>
      </div>
      <div class="grid-4">
        {homeFeatureTiles.map((feature) => (
          <article class="card">
            <Icon name={feature.icon} size={22} />
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container split">
      <figure class="media-frame">
        <img
          src="/images/team/robert-garcia-state-48-credit-founder.avif"
          alt="Robert Garcia, founder of State 48 Credit in Phoenix Arizona"
          width="900"
          height="1125"
          loading="lazy"
          decoding="async"
        />
      </figure>
      <div class="section-head">
        <p class="eyebrow">Founder-led</p>
        <h2>You talk to a credit repair specialist, not a call center.</h2>
        {homeTestimonials.map((item) => (
          <article class="card">
            <h3>{item.result}</h3>
            <p>"{item.quote}"</p>
            <p><strong>{item.name}</strong> - {item.city}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Arizona-wide</p>
        <h2>{homeServiceArea.title}</h2>
        <p>{homeServiceArea.description}</p>
      </div>
      <div class="grid-2">
        <article class="card">
          <h3>Metro Phoenix</h3>
          <p>{homeServiceArea.metroPhoenix.map((city) => city.name).join(", ")}</p>
        </article>
        <article class="card">
          <h3>Statewide</h3>
          <p>{homeServiceArea.statewide.map((city) => city.name).join(", ")}</p>
        </article>
      </div>
    </div>
  </section>

  <section id="faq" class="section below-fold">
    <div class="narrow">
      <div class="section-head">
        <p class="eyebrow">FAQ</p>
        <h2>Frequently asked questions about Arizona credit repair.</h2>
      </div>
      <div class="faq-list">
        {homeFaq.map((item) => (
          <details>
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Credit education</p>
        <h2>Latest State 48 guides.</h2>
      </div>
      <div class="grid-2">
        {posts.map((post) => (
          <article class="article-card">
            <p class="eyebrow">{post.category}</p>
            <h2><a href={`/blog/${post.slug}/`} data-astro-prefetch>{post.title}</a></h2>
            <p>{post.excerpt}</p>
            <a class="text-link" href={`/blog/${post.slug}/`} data-astro-prefetch>Read guide <Icon name="arrow-right" size={14} /></a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
