---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomePage from "../../app/page";
import { serviceSchema } from "@/lib/schema";
import inlineCss1 from "../styles/pages/home.css?raw";
import inlineCss2 from "../styles/heading-system.css?raw";
---

<BaseLayout
  inlineStyles={[inlineCss1, inlineCss2].join("\n")}
  title="Hard Inquiry Removal Service | Inquiry Removal"
  description="Remove unauthorized hard inquiries from your credit report — all 3 bureaus. 100,437+ deleted since 2015. Free consultation. Flat fee. 100% money-back guarantee."
  canonicalPath="/"
  ogImage="/og/home.png"
  ogImageAlt="Inquiry Removal hard inquiry removal service for Experian, Equifax, and TransUnion."
  schema={serviceSchema}
  pathname={Astro.url.pathname}
>
  <HomePage />
</BaseLayout>
