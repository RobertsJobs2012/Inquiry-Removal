---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import { formatBlogDate, getAllBlogPosts } from "../../../lib/blog";
import { collectionPageSchema, breadcrumbSchema } from "../../../lib/schema";

const posts = getAllBlogPosts();
---

<BaseLayout
  title="Credit Repair Blog Arizona"
  description="Credit repair guides from State 48 Credit covering Arizona credit repair, hard inquiry removal, report disputes, and avoiding credit repair scams."
  path="/blog"
  schema={[
    collectionPageSchema({
      name: "State 48 Credit Blog",
      path: "/blog",
      description: "Arizona credit repair education and guides.",
    }),
    breadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Blog", path: "/blog" },
    ]),
  ]}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Credit education</p>
        <h1>Arizona credit repair guides written for real decisions.</h1>
        <p>Practical, no-hype guidance on what can be disputed, what usually stays, how inquiry removal works, and how to avoid credit repair companies that waste your time.</p>
      </div>
      <article class="card stat-card">
        <strong>{posts.length}</strong>
        <span>deep guides and growing.</span>
      </article>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container grid-2">
      {posts.map((post) => (
        <article class="article-card">
          {post.coverImage ? <img src={post.coverImage} alt={post.coverAlt} width="1200" height="1501" loading="lazy" decoding="async" /> : null}
          <p class="eyebrow">{post.category} - {formatBlogDate(post.publishDate)}</p>
          <h2><a href={`/blog/${post.slug}/`} data-astro-prefetch>{post.title}</a></h2>
          <p>{post.excerpt}</p>
          <a class="text-link" href={`/blog/${post.slug}/`} data-astro-prefetch>
            Read guide <Icon name="arrow-right" size={14} />
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
