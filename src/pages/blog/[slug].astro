---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import {
  formatBlogDate,
  getAllBlogPosts,
  getBlogSectionId,
} from "../../../lib/blog";
import { getStartedPagePath } from "../../../lib/getStartedPage";
import { blogPostingSchema, breadcrumbSchema, faqSchema } from "../../../lib/schema";

export function getStaticPaths() {
  return getAllBlogPosts().map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<BaseLayout
  title={post.seoTitle}
  description={post.seoDescription}
  path={`/blog/${post.slug}`}
  ogImage={post.coverImage}
  imageAlt={post.coverAlt}
  schema={[
    blogPostingSchema(post),
    faqSchema(post.faq),
    breadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Blog", path: "/blog" },
      { name: post.title, path: `/blog/${post.slug}` },
    ]),
  ]}
>
  <article>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">{post.eyebrow}</p>
          <h1>{post.title}</h1>
          <p>{post.description}</p>
          <p>{formatBlogDate(post.publishDate)} - {post.readTime}</p>
        </div>
        {post.coverImage ? (
          <figure class="hero-media">
            <img src={post.coverImage} alt={post.coverAlt} width="1200" height="1501" loading="eager" fetchpriority="high" />
            <figcaption>
              <strong>{post.category}</strong>
              <span>Written by Robert Garcia</span>
            </figcaption>
          </figure>
        ) : null}
      </div>
    </section>

    <section class="section below-fold">
      <div class="narrow article-body">
        <div class="callout">
          <p class="eyebrow">Quick answer</p>
          <p>{post.quickAnswer}</p>
        </div>

        <section>
          <h2>Key takeaways</h2>
          <ul class="check-list">
            {post.keyTakeaways.map((item) => <li><Icon name="check" size={16} /><span>{item}</span></li>)}
          </ul>
        </section>

        <div class="grid-3">
          {post.summaryStats.map((stat) => (
            <article class="card stat-card">
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
              {stat.detail ? <p>{stat.detail}</p> : null}
            </article>
          ))}
        </div>

        <section>
          <p>{post.intro}</p>
        </section>

        {post.comparison ? (
          <section>
            <h2>{post.comparison.title}</h2>
            <p>{post.comparison.description}</p>
            <div class="grid-2">
              {[post.comparison.left, post.comparison.right].map((column) => (
                <article class="card">
                  <p class="eyebrow">{column.label}</p>
                  <h3>{column.title}</h3>
                  <ul class="check-list">
                    {column.bullets.map((item) => <li><Icon name="check" size={16} /><span>{item}</span></li>)}
                  </ul>
                </article>
              ))}
            </div>
          </section>
        ) : null}

        {post.sections.map((section) => (
          <section id={getBlogSectionId(section.heading)}>
            <h2>{section.heading}</h2>
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            {section.bullets ? (
              <ul class="check-list">
                {section.bullets.map((item) => <li><Icon name="check" size={16} /><span>{item}</span></li>)}
              </ul>
            ) : null}
          </section>
        ))}

        {post.proofCard ? (
          <section class="card">
            <p class="eyebrow">{post.proofCard.badge}</p>
            <h2>{post.proofCard.title}</h2>
            <p>{post.proofCard.description}</p>
            {post.proofCard.image ? <img src={post.proofCard.image} alt={post.proofCard.imageAlt} width="1200" height="1501" loading="lazy" decoding="async" /> : null}
            <p>"{post.proofCard.quote}"</p>
            <p><strong>{post.proofCard.attribution}</strong></p>
            <a class="text-link" href={post.proofCard.ctaHref}>{post.proofCard.ctaLabel} <Icon name="arrow-right" size={14} /></a>
          </section>
        ) : null}

        <section>
          <h2>Frequently asked questions</h2>
          <div class="faq-list">
            {post.faq.map((item) => (
              <details>
                <summary>{item.q}</summary>
                <p>{item.a}</p>
              </details>
            ))}
          </div>
        </section>

        <section class="callout">
          <h2>{post.finalCtaTitle}</h2>
          <p>{post.finalCtaBody}</p>
          <div class="cta-row">
            <a class="button button-primary" href={post.cta.href}>{post.cta.label}</a>
            <a class="button button-secondary" href={post.cta.secondaryHref ?? getStartedPagePath}>{post.cta.secondaryLabel ?? "Start a free consultation"}</a>
          </div>
        </section>
      </div>
    </section>
  </article>
</BaseLayout>
