---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { resultsGallery } from "../../lib/resultsGallery";
import { getStartedPagePath } from "../../lib/getStartedPage";
import { stats } from "../../lib/site";
import { breadcrumbSchema, collectionPageSchema } from "../../lib/schema";
---

<BaseLayout
  title="Credit Repair Results Arizona | State 48 Credit"
  description="See State 48 Credit client results across Arizona: score increases, collections removed, identity-theft recovery, mortgage-ready files, and approval-focused outcomes."
  path="/credit-repair-results-arizona"
  schema={[
    collectionPageSchema({
      name: "Arizona Credit Repair Results",
      path: "/credit-repair-results-arizona",
      description: "Static gallery of Arizona credit repair outcomes from State 48 Credit.",
    }),
    breadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Results", path: "/credit-repair-results-arizona" },
    ]),
  ]}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Real results</p>
        <h1>Arizona credit repair results tied to real approvals.</h1>
        <p>State 48 Credit has removed {stats.itemsRemoved.toLocaleString()} negative items for {stats.clientsServed.toLocaleString()} clients since 2010.</p>
        <a class="button button-primary" href={getStartedPagePath} data-astro-prefetch>Start Free Audit</a>
      </div>
      <article class="card stat-card">
        <strong>{stats.rating.toFixed(1)} stars</strong>
        <span>{stats.reviews} verified reviews and a 90-day money-back guarantee.</span>
      </article>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container">
      <div class="results-grid">
        {resultsGallery.map((item) => (
          <article class="result-card">
            <img src={item.imageSrc} alt={item.imageAlt} width="1200" height="1501" loading="lazy" decoding="async" />
            <div>
              <p class="score">{item.score}</p>
              <p class="eyebrow">{item.tag}</p>
              <h2>{item.name}</h2>
              <p>{item.city} - {item.timeframe}</p>
              <p>{item.detail}</p>
              <p>"{item.quote}"</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container grid-3">
      <article class="card stat-card"><strong>{stats.itemsRemoved.toLocaleString()}</strong><span>negative items removed</span></article>
      <article class="card stat-card"><strong>${stats.debtEliminated}</strong><span>derogatory debt eliminated</span></article>
      <article class="card stat-card"><strong>{stats.yearsInBusiness}</strong><span>years serving Arizona</span></article>
    </div>
  </section>

  <section class="section below-fold">
    <div class="narrow callout">
      <h2>Want to know what can come off your report?</h2>
      <p>The free audit shows which items are inaccurate, outdated, unverifiable, or tied to identity-theft damage before you commit.</p>
      <a class="button button-primary" href={getStartedPagePath} data-astro-prefetch>
        Start Free Audit <Icon name="arrow-right" size={17} />
      </a>
    </div>
  </section>
</BaseLayout>
