---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { getStartedPagePath } from "../../lib/getStartedPage";
import { founder, site, stats } from "../../lib/site";
import { breadcrumbSchema, localBusinessSchema, personSchema } from "../../lib/schema";
---

<BaseLayout
  title="About Robert Garcia and State 48 Credit"
  description="Meet Robert Garcia, founder of State 48 Credit, identity-theft survivor, and Arizona credit repair strategist serving clients since 2010."
  path="/about"
  schema={[
    personSchema(),
    localBusinessSchema(),
    breadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "About", path: "/about" },
    ]),
  ]}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{founder.role}</p>
        <h1>Built by an identity-theft survivor who knows how the system really works.</h1>
        <p>{founder.story}</p>
        <a class="button button-primary" href={getStartedPagePath} data-astro-prefetch>Talk to Robert</a>
      </div>
      <figure class="hero-media">
        <img src={founder.photo} alt="Robert Garcia, founder of State 48 Credit" width="900" height="1125" loading="eager" fetchpriority="high" />
        <figcaption>
          <strong>{founder.name}</strong>
          <span>{founder.city}</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section id="mission" class="section below-fold">
    <div class="container split">
      <div class="section-head">
        <p class="eyebrow">Mission</p>
        <h2>Make credit repair clear, honest, and tied to real outcomes.</h2>
        <p>State 48 Credit was created as the opposite of the open-ended monthly billing model: defined scope, custom disputes, direct accountability, and an honest explanation of what can and cannot be removed.</p>
      </div>
      <div class="grid-2">
        <article class="card stat-card"><strong>{stats.clientsServed.toLocaleString()}</strong><span>clients served</span></article>
        <article class="card stat-card"><strong>{stats.itemsRemoved.toLocaleString()}</strong><span>items removed</span></article>
        <article class="card stat-card"><strong>{stats.yearsInBusiness}</strong><span>years in business</span></article>
        <article class="card stat-card"><strong>{stats.rating.toFixed(1)}</strong><span>star rating</span></article>
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container grid-3">
      {[
        ["Custom disputes", "Every item gets a specific argument, not a generic template."],
        ["Founder-led strategy", "You work with a specialist who understands bureau process and client pressure."],
        ["Arizona-wide service", `${site.name} serves Phoenix and cities across Arizona remotely.`],
      ].map(([title, body]) => (
        <article class="card">
          <Icon name="shield" size={22} />
          <h2>{title}</h2>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
