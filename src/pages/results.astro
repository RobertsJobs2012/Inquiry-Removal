---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResultsPage, { metadata } from "../../app/results/page";
import { resultsPageSchema } from "@/lib/schema";
import inlineCss1 from "../styles/pages/results.css.txt?raw";
import inlineCss2 from "../styles/heading-system.css.txt?raw";

const meta = metadata as any;
---

<BaseLayout
  inlineStyles={[inlineCss1, inlineCss2].join("\n")}
  title={meta.title.absolute}
  description={meta.description}
  canonicalPath={meta.alternates.canonical}
  ogImage="/og/results.png"
  ogImageAlt="Inquiry Removal client results and hard inquiries removed from credit reports."
  schema={resultsPageSchema}
  pathname={Astro.url.pathname}
>
  <ResultsPage />
</BaseLayout>
