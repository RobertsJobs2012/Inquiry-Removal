---
import BaseLayout from "../layouts/BaseLayout.astro";
import { LandingPage } from "../../components/LandingPage";
import { landingPageByKey } from "@/lib/landing-pages";
import inlineCss1 from "../styles/pages/experian.css?raw";
import inlineCss2 from "../styles/pages/landing.css?raw";
import inlineCss3 from "../styles/heading-system.css?raw";

const page = landingPageByKey.dealer;
---

<BaseLayout
  inlineStyles={[inlineCss1, inlineCss2, inlineCss3].join("\n")}
  title={page.metaTitle}
  description={page.metaDescription}
  canonicalPath={page.slug}
  ogImage={page.ogImage}
  ogImageAlt={`${page.metaTitle} preview.`}
  pathname={Astro.url.pathname}
>
  <LandingPage page={page} />
</BaseLayout>
