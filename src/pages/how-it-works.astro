---
import BaseLayout from "../layouts/BaseLayout.astro";
import HowItWorksPage, { metadata } from "../../app/how-it-works/page";
import { howItWorksPageSchema } from "@/lib/schema";
import "../styles/pages/how-it-works.css";
import "../styles/heading-system.css";

const meta = metadata as any;
---

<BaseLayout
  title={meta.title.absolute}
  description={meta.description}
  canonicalPath={meta.alternates.canonical}
  ogImage="/og/how-it-works.png"
  ogImageAlt="The Inquiry Removal process from free analysis to bureau disputes and results."
  schema={howItWorksPageSchema}
  pathname={Astro.url.pathname}
>
  <HowItWorksPage />
</BaseLayout>
