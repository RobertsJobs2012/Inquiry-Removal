---
import BaseLayout from "../layouts/BaseLayout.astro";
import PrivacyPolicyPage, { metadata } from "../../app/privacy-policy/page";
import inlineCss1 from "../styles/pages/experian.css.txt?raw";
import inlineCss2 from "../styles/pages/privacy-policy.css.txt?raw";
import inlineCss3 from "../styles/heading-system.css.txt?raw";

const meta = metadata as any;
---

<BaseLayout
  inlineStyles={[inlineCss1, inlineCss2, inlineCss3].join("\n")}
  title={meta.title.absolute}
  description={meta.description}
  canonicalPath={meta.alternates.canonical}
  ogImage="/og/faq.png"
  ogImageAlt="Inquiry Removal privacy policy and data protection information."
  pathname={Astro.url.pathname}
>
  <PrivacyPolicyPage />
</BaseLayout>
