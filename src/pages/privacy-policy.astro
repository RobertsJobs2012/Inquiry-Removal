---
import BaseLayout from "../layouts/BaseLayout.astro";
import PrivacyPolicyPage, { metadata } from "../../app/privacy-policy/page";
import "../styles/pages/privacy-policy.css";
import "../styles/heading-system.css";

const meta = metadata as any;
---

<BaseLayout
  title={meta.title.absolute}
  description={meta.description}
  canonicalPath={meta.alternates.canonical}
  ogImage="/og/faq.png"
  ogImageAlt="Inquiry Removal privacy policy and data protection information."
  pathname={Astro.url.pathname}
>
  <PrivacyPolicyPage />
</BaseLayout>
