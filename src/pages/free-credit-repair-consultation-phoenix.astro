---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import { site } from "../../lib/site";
import { breadcrumbSchema } from "../../lib/schema";
---

<BaseLayout
  title="Free Credit Repair Consultation Phoenix"
  description="Book a free credit repair consultation with State 48 Credit. Review your report, identify removable items, and get a clear Arizona credit repair plan."
  path="/free-credit-repair-consultation-phoenix"
  schema={breadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Free Consultation", path: "/free-credit-repair-consultation-phoenix" },
  ])}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Free audit</p>
        <h1>Find out what can come off your credit report before you pay anything.</h1>
        <p>Use the quick form below or call Robert directly. The consultation is no pressure, no obligation, and focused on what your report actually needs.</p>
        <a class="button button-secondary" href={site.phoneHref}><Icon name="phone" size={17} />Call {site.phone}</a>
      </div>
      <article class="card">
        <h2>What we review</h2>
        <ul class="check-list">
          {["All three bureau reports", "Collections and charge-offs", "Late payments and repossessions", "Inquiry and fraud damage", "The smallest package that fits"].map((item) => (
            <li><Icon name="check" size={16} /><span>{item}</span></li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <section class="section below-fold">
    <div class="narrow">
      <form class="card form-grid" action={site.emailHref} method="post" enctype="text/plain">
        <div class="form-row">
          <label for="name">Full name</label>
          <input id="name" name="name" autocomplete="name" required />
        </div>
        <div class="form-row">
          <label for="phone">Phone number</label>
          <input id="phone" name="phone" type="tel" autocomplete="tel" required />
        </div>
        <div class="form-row">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" />
        </div>
        <div class="form-row">
          <label for="goal">Primary goal</label>
          <select id="goal" name="goal" required>
            <option value="">Choose one</option>
            <option>Buy a home</option>
            <option>Get a car loan</option>
            <option>Remove collections</option>
            <option>Recover from identity theft</option>
            <option>Not sure yet</option>
          </select>
        </div>
        <div class="form-row">
          <label for="message">What is happening on your report?</label>
          <textarea id="message" name="message"></textarea>
        </div>
        <button class="button button-primary" type="submit">Send Free Audit Request</button>
        <p>Prefer not to use email? Call <a class="text-link" href={site.phoneHref}>{site.phone}</a>.</p>
      </form>
    </div>
  </section>
</BaseLayout>
