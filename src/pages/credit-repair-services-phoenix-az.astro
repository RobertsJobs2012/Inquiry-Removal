---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import {
  servicesAddOns,
  servicesDiySection,
  servicesFaq,
  servicesFinalCta,
  servicesHero,
  servicesNotSureSection,
  servicesPackageComparison,
  servicesPackages,
  servicesPageMeta,
  servicesSelectorCards,
} from "../../lib/servicesPage";
import { getStartedPagePath } from "../../lib/getStartedPage";
import { breadcrumbSchema, faqSchema, servicePackageSchemas, serviceSchema } from "../../lib/schema";
---

<BaseLayout
  title={servicesPageMeta.title}
  description={servicesPageMeta.description}
  path="/credit-repair-services-phoenix-az"
  ogTitle={servicesPageMeta.ogTitle}
  ogDescription={servicesPageMeta.ogDescription}
  schema={[
    serviceSchema(),
    faqSchema(servicesFaq),
    ...servicePackageSchemas(servicesPackages),
    breadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Credit Repair Services", path: "/credit-repair-services-phoenix-az" },
    ]),
  ]}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Credit repair services</p>
        <h1>{servicesHero.title}</h1>
        <p>{servicesHero.description}</p>
        <p>{servicesHero.subheadline}</p>
        <div class="hero-actions">
          <a class="button button-primary" href={getStartedPagePath} data-astro-prefetch>Start Free Audit</a>
          <a class="button button-secondary" href="#packages">View packages</a>
        </div>
      </div>
      <div class="grid-1">
        {servicesHero.stats.map((stat) => (
          <article class="card stat-card">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="solution-selector" class="section below-fold">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Start with your situation</p>
        <h2>Choose the problem you are solving.</h2>
      </div>
      <div class="grid-4">
        {servicesSelectorCards.map((card) => (
          <article class="card">
            <Icon name={card.icon} size={22} />
            <p class="eyebrow">{card.eyebrow}</p>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
            <a class="text-link" href={card.href}>{card.cta} <Icon name="arrow-right" size={14} /></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="packages" class="section below-fold">
    <div class="container">
      <div class="section-head center">
        <p class="eyebrow">Flat-fee packages</p>
        <h2>Defined scope. Transparent price. No monthly billing.</h2>
      </div>
      <div class="grid-3">
        {servicesPackages.map((pkg) => (
          <article id={pkg.slug} class:list={["pricing-card", { featured: pkg.tone === "featured" }]}>
            {"badge" in pkg ? <span class="badge">{pkg.badge}</span> : null}
            <h3>{pkg.name}</h3>
            <p>{pkg.subtitle}</p>
            <p class="price">${pkg.price}<small> one-time</small></p>
            <p>{pkg.problem}</p>
            <ul class="check-list">
              {pkg.included.slice(0, 7).map((item) => (
                <li><Icon name="check" size={16} /><span>{item}</span></li>
              ))}
            </ul>
            <p><strong>Best for:</strong> {pkg.bestFor}</p>
            <a class="button button-primary" href={getStartedPagePath} data-astro-prefetch>{pkg.cta}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Add-ons</p>
        <h2>Targeted cleanup for inquiry and specialty-report damage.</h2>
      </div>
      <div class="grid-4">
        {servicesAddOns.map((addon) => (
          <article class="card">
            {"popular" in addon ? <span class="badge">Popular</span> : null}
            <Icon name={addon.icon} size={22} />
            <h3>{addon.name}</h3>
            <p>{addon.detail}</p>
            <p class="price">${addon.price}</p>
            <p>{addon.note}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Compare</p>
        <h2>Package comparison.</h2>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Feature</th>
              <th>One & Done</th>
              <th>Full Sweep</th>
              <th>Total Freedom</th>
            </tr>
          </thead>
          <tbody>
            {servicesPackageComparison.map((row) => (
              <tr>
                <th scope="row">{row.label}</th>
                <td>{row.oneAndDone}</td>
                <td>{row.fullSweep}</td>
                <td>{row.totalFreedom}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section below-fold">
    <div class="container grid-2">
      {servicesDiySection.sections.map((section) => (
        <article class="card">
          <p class="eyebrow">DIY vs professional</p>
          <h2>{section.heading}</h2>
          {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </article>
      ))}
    </div>
  </section>

  <section class="section below-fold">
    <div class="container split">
      <div class="section-head">
        <p class="eyebrow">Not sure?</p>
        <h2>{servicesNotSureSection.title}</h2>
        <p>{servicesNotSureSection.body}</p>
        <p>{servicesNotSureSection.serviceArea}</p>
      </div>
      <article class="card">
        <h3>{servicesFinalCta.title}</h3>
        <p>{servicesFinalCta.body}</p>
        <div class="cta-row">
          <a class="button button-primary" href={getStartedPagePath} data-astro-prefetch>{servicesFinalCta.primary}</a>
          <a class="button button-secondary" href="/how-credit-repair-works/" data-astro-prefetch>{servicesFinalCta.secondary}</a>
        </div>
        <p>{servicesFinalCta.fearKiller}</p>
      </article>
    </div>
  </section>

  <section class="section below-fold">
    <div class="narrow">
      <div class="section-head">
        <p class="eyebrow">FAQ</p>
        <h2>Credit repair service questions.</h2>
      </div>
      <div class="faq-list">
        {servicesFaq.map((item) => (
          <details>
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
