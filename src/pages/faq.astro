---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQPage, { metadata } from "../../app/faq/page";
import "../styles/pages/faq.css";
import "../styles/heading-system.css";

const meta = metadata as any;
---

<BaseLayout
  title={meta.title.absolute}
  description={meta.description}
  canonicalPath={meta.alternates.canonical}
  ogImage="/og/faq.png"
  ogImageAlt="Hard inquiry removal FAQ for Experian, Equifax, and TransUnion."
  pathname={Astro.url.pathname}
>
  <FAQPage />
</BaseLayout>
