---
import BaseLayout from "../layouts/BaseLayout.astro";
import TransUnionPage, { metadata } from "../../app/remove-hard-inquiry-transunion/page";
import "../styles/pages/transunion.css";

const meta = metadata as any;
---

<BaseLayout
  title={meta.title.absolute}
  description={meta.description}
  canonicalPath={meta.alternates.canonical}
  pathname={Astro.url.pathname}
>
  <TransUnionPage />
</BaseLayout>
