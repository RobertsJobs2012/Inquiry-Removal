---
import BaseLayout from "../layouts/BaseLayout.astro";
import TransUnionPage, { metadata } from "../../app/remove-hard-inquiry-transunion/page";
import inlineCss1 from "../styles/pages/transunion.css?raw";
import inlineCss2 from "../styles/heading-system.css?raw";

const meta = metadata as any;
---

<BaseLayout
  inlineStyles={[inlineCss1, inlineCss2].join("\n")}
  title={meta.title.absolute}
  description={meta.description}
  canonicalPath={meta.alternates.canonical}
  ogImage="/og/transunion.png"
  ogImageAlt="TransUnion hard inquiry removal service preview."
  pathname={Astro.url.pathname}
>
  <TransUnionPage />
</BaseLayout>
