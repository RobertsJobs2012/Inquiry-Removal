---
import BaseLayout from "../layouts/BaseLayout.astro";
import { AnnouncementBar } from "../../components/AnnouncementBar";
import { Footer } from "../../components/Footer";
import { Navigation } from "../../components/Navigation";
import GetStartedQuizStatic from "../components/GetStartedQuizStatic.astro";
import inlineCss1 from "../styles/pages/get-started.css.txt?raw";
import inlineCss2 from "../styles/heading-system.css.txt?raw";

const pageTitle = "Get Started — Free Hard Inquiry Removal Consultation";
const pageDescription = "Book your free 15-minute credit consultation. We review your report, count your inquiries, and tell you exactly what can be removed — before you spend anything.";
---

<BaseLayout
  inlineStyles={[inlineCss1, inlineCss2].join("\n")}
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/get-started/"
  ogImage="/og/get-started.png"
  ogImageAlt="Inquiry Removal free analysis preview with Experian, Equifax, and TransUnion proof signals."
  pathname={Astro.url.pathname}
>
  <AnnouncementBar />
  <Navigation activePath="/get-started" />
  <main id="main" class="get-started-page-main">
    <GetStartedQuizStatic />
  </main>
  <Footer />
</BaseLayout>
