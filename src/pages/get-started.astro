---
import BaseLayout from "../layouts/BaseLayout.astro";
import GetStartedPage, { metadata } from "../../app/get-started/page";
import "../styles/pages/get-started.css";
import "../styles/heading-system.css";

const meta = metadata as any;
---

<BaseLayout
  title={meta.title.absolute}
  description={meta.description}
  canonicalPath={meta.alternates.canonical}
  pathname={Astro.url.pathname}
>
  <GetStartedPage client:idle />
</BaseLayout>
