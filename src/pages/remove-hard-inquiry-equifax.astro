---
import BaseLayout from "../layouts/BaseLayout.astro";
import EquifaxPage, { metadata } from "../../app/remove-hard-inquiry-equifax/page";
import inlineCss1 from "../styles/pages/equifax.css?raw";
import inlineCss2 from "../styles/heading-system.css?raw";

const meta = metadata as any;
---

<BaseLayout
  inlineStyles={[inlineCss1, inlineCss2].join("\n")}
  title={meta.title.absolute}
  description={meta.description}
  canonicalPath={meta.alternates.canonical}
  ogImage="/og/equifax.png"
  ogImageAlt="Equifax hard inquiry removal service preview."
  pathname={Astro.url.pathname}
>
  <EquifaxPage />
</BaseLayout>
