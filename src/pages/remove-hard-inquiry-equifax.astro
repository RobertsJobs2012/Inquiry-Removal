---
import BaseLayout from "../layouts/BaseLayout.astro";
import EquifaxPage, { metadata } from "../../app/remove-hard-inquiry-equifax/page";
import "../styles/pages/equifax.css";

const meta = metadata as any;
---

<BaseLayout
  title={meta.title.absolute}
  description={meta.description}
  canonicalPath={meta.alternates.canonical}
  pathname={Astro.url.pathname}
>
  <EquifaxPage />
</BaseLayout>
