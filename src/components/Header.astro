---
import Icon from "./Icon.astro";
import Logo from "./Logo.astro";
import { nav, site } from "../../lib/site";
import { getStartedPagePath } from "../../lib/getStartedPage";
import { servicesMenuCards, servicesPagePath } from "../../lib/servicesPage";
---

<a href="#main" class="skip-link">Skip to main content</a>
<div class="announcement" data-announcement>
  <a class="announcement-message" href={getStartedPagePath} data-astro-prefetch>
    <span>AZ clients: 50% off packages + add-ons</span>
    <strong>Claim free audit</strong>
  </a>
  <button class="announcement-close" type="button" aria-label="Dismiss announcement" data-announcement-close>
    <Icon name="close" size={16} />
  </button>
</div>
<header class="site-header" data-mobile-header>
  <div class="nav-wrap">
    <Logo />

    <nav class="desktop-nav" aria-label="Primary">
      <ul>
        {nav.map((item) => (
          item.href === servicesPagePath ? (
            <li class="nav-services">
              <details>
                <summary>
                  <span>{item.label}</span>
                  <Icon name="chevron-down" size={14} />
                </summary>
                <div class="mega-menu">
                  <p class="eyebrow">Choose a service</p>
                  <ul>
                    {servicesMenuCards.slice(0, 3).map((service) => (
                      <li>
                        <a href={service.href} data-astro-prefetch>
                          <Icon name={service.icon} size={18} />
                          <span>
                            <strong>{service.title}</strong>
                            <small>{service.summary}</small>
                          </span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </details>
            </li>
          ) : (
            <li><a href={item.href} data-astro-prefetch>{item.label}</a></li>
          )
        ))}
      </ul>
    </nav>

    <div class="nav-actions">
      <a class="phone-link" href={site.phoneHref} aria-label={`Call State 48 Credit at ${site.phone}`}>
        <Icon name="phone" size={17} />
        <span class="phone-text">{site.phone}</span>
      </a>
      <a class="button button-primary nav-cta" href={getStartedPagePath} data-astro-prefetch>Start Free Audit</a>
      <details class="mobile-menu" data-mobile-menu>
        <summary aria-label="Open navigation menu">
          <Icon name="menu" size={22} />
          <span>Menu</span>
        </summary>
        <nav aria-label="Mobile navigation">
          <div class="mobile-menu-top">
            <Logo compact />
            <span class="mobile-menu-kicker">Arizona credit repair</span>
          </div>
          <a href={servicesPagePath} data-astro-prefetch>Services</a>
          {nav.filter((item) => item.href !== servicesPagePath).map((item) => (
            <a href={item.href} data-astro-prefetch>{item.label}</a>
          ))}
          <a class="mobile-menu-cta" href={getStartedPagePath} data-astro-prefetch>Start Free Audit</a>
          <a class="mobile-menu-call" href={site.phoneHref}>Call {site.phone}</a>
        </nav>
      </details>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const announcement = document.querySelector("[data-announcement]");
    const closeButton = document.querySelector("[data-announcement-close]");
    const header = document.querySelector("[data-mobile-header]");
    const menu = document.querySelector("[data-mobile-menu]");
    const announcementKey = "state48-announcement-dismissed";

    if (announcement && sessionStorage.getItem(announcementKey) === "true") {
      announcement.hidden = true;
    }

    closeButton?.addEventListener("click", () => {
      sessionStorage.setItem(announcementKey, "true");
      if (announcement) announcement.hidden = true;
    });

    const updateHeader = () => {
      header?.classList.toggle("is-scrolled", window.scrollY > 16);
    };

    updateHeader();
    window.addEventListener("scroll", updateHeader, { passive: true });

    menu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.removeAttribute("open");
      });
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") menu?.removeAttribute("open");
    });
  })();
</script>
