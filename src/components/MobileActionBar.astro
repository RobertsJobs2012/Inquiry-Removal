---
import Icon from "./Icon.astro";
import { site } from "../../lib/site";
import { getStartedPagePath } from "../../lib/getStartedPage";
---

<nav class="mobile-action-bar" aria-label="Fast mobile actions">
  <a class="mobile-action-call" href={site.phoneHref} aria-label={`Call State 48 Credit at ${site.phone}`}>
    <Icon name="phone" size={18} />
    <span>Call Now</span>
  </a>
  <a class="mobile-action-audit" href={getStartedPagePath} data-astro-prefetch>
    <Icon name="sparkles" size={18} />
    <span>Free Audit</span>
  </a>
</nav>
