---
type DockConfig = {
  label: string;
  href: string;
  ariaLabel: string;
};

const { pathname = "/" } = Astro.props;

const defaultAction: DockConfig = {
  label: "Free Analysis",
  href: "/get-started/",
  ariaLabel: "Start your free inquiry analysis",
};

function getDockAction(currentPath: string): DockConfig {
  if (currentPath.startsWith("/pricing")) {
    return {
      label: "Choose Plan",
      href: "/pricing/#pricing-plans",
      ariaLabel: "Choose the best inquiry removal plan",
    };
  }

  if (currentPath.startsWith("/services")) {
    return {
      label: "Find Service",
      href: "/services/",
      ariaLabel: "Find the right inquiry removal service",
    };
  }

  if (currentPath.startsWith("/results")) {
    return {
      label: "Check Fit",
      href: "/get-started/",
      ariaLabel: "Check whether your inquiries may qualify for removal",
    };
  }

  if (currentPath.includes("experian")) {
    return {
      label: "Experian Help",
      href: "/get-started/?bureau=experian",
      ariaLabel: "Start Experian inquiry removal help",
    };
  }

  if (currentPath.includes("equifax")) {
    return {
      label: "Equifax Help",
      href: "/get-started/?bureau=equifax",
      ariaLabel: "Start Equifax inquiry removal help",
    };
  }

  if (currentPath.includes("transunion")) {
    return {
      label: "TransUnion Help",
      href: "/get-started/?bureau=transunion",
      ariaLabel: "Start TransUnion inquiry removal help",
    };
  }

  if (currentPath.startsWith("/faq")) {
    return {
      label: "Ask Us",
      href: "/get-started/",
      ariaLabel: "Ask Inquiry Removal a question",
    };
  }

  return defaultAction;
}

const action = getDockAction(pathname);
---

<aside class="mobile-conversion-dock" aria-label="Quick contact actions">
  <div class="mobile-conversion-dock-inner">
    <a
      href="tel:+16023776626"
      class="mobile-dock-action mobile-dock-action-secondary"
      aria-label="Call Inquiry Removal at (602) 377-6626"
      data-event="mobile_dock_call_click"
    >
      <span>Call</span>
    </a>
    <a
      href="sms:+16023776626"
      class="mobile-dock-action mobile-dock-action-secondary"
      aria-label="Text Inquiry Removal at (602) 377-6626"
      data-event="mobile_dock_text_click"
    >
      <span>Text</span>
    </a>
    <a
      href={action.href}
      class="mobile-dock-action mobile-dock-action-primary"
      aria-label={action.ariaLabel}
      data-event="mobile_dock_primary_click"
      data-dock-label={action.label}
      data-astro-prefetch
    >
      <span>{action.label}</span>
      <span aria-hidden="true">→</span>
    </a>
  </div>
</aside>
