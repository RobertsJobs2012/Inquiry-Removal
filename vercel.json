{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/contact", "destination": "/free-credit-repair-consultation-phoenix", "permanent": true },
    { "source": "/services", "destination": "/credit-repair-services-phoenix-az", "permanent": true },
    { "source": "/pricing", "destination": "/credit-repair-cost-phoenix-az", "permanent": true },
    { "source": "/results", "destination": "/credit-repair-results-arizona", "permanent": true },
    { "source": "/book", "destination": "/book-credit-repair-consultation-phoenix", "permanent": true },
    { "source": "/comparison", "destination": "/compare-credit-repair-companies-arizona", "permanent": true },
    { "source": "/how-it-works", "destination": "/how-credit-repair-works", "permanent": true },
    { "source": "/get-started", "destination": "/free-credit-repair-consultation-phoenix", "permanent": true },
    { "source": "/inquiry-removal-service", "destination": "/hard-inquiry-removal", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/scripts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
